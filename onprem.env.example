# TTS On-Prem Configuration
# Copy this file to onprem.env and update with your values
#
# Usage:
#   cp onprem.env.example onprem.env
#   # Edit onprem.env with your values
#   ./run.sh
#
# Two metering modes are supported:
#   Mode A (new):    Inworld API key → gRPC-based metering via api.inworld.ai
#   Mode B (legacy): Customer ID + GCP SA → PubSub-based metering

# Docker image URL (required for both modes)
# Available images: tts-1.5-mini-h100-onprem, tts-1.5-max-h100-onprem
TTS_IMAGE=us-central1-docker.pkg.dev/inworld-ai-registry/tts-onprem/tts-1.5-mini-h100-onprem:YYYYMMDD-gitsha

# =============================================================================
# Mode A: Inworld API key (Coming soon!)
# =============================================================================
# API key from Inworld Studio > Workspace > API Keys.
# GCP service account key is NOT required in this mode.
# INWORLD_API_KEY=

# Inworld API endpoint (default: https://api.inworld.ai)
# INWORLD_API_ENDPOINT=https://api.inworld.ai

# INWORLD_ENABLE_AUTH_VALIDATION=false

# =============================================================================
# Mode B: Customer ID + GCP service account (legacy)
# =============================================================================
# Your customer ID (provided by Inworld)
INWORLD_CUSTOMER_ID=example-customer

# Path to your GCP service account key file
KEY_FILE=./service-account-key.json
